<p style="color: green"><%= notice %></p>

<h1><%= t('books.index.page_title') %></h1>

<div id="books">
  <% @books.each do |book| %>
    <%= render book %>
    <p>
      <%= link_to t('books.index.show'), book %>
    </p>
  <% end %>
</div>

<%= link_to t('books.index.new_book'), new_book_path %>
