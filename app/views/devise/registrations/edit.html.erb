<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :patch }) do |f| %>
<div class="field">
  <%= f.label :name %><br />
  <%= f.text_field :name %>
</div>

<div class="field">
  <%= f.label :postal_code %><br />
  <%= f.text_field :postal_code %>
</div>

<div class="field">
  <%= f.label :address %><br />
  <%= f.text_field :address %>
</div>

<div class="field">
  <%= f.label :bio %><br />
  <%= f.text_area :bio %>
</div>

  <div class="actions">
    <%= f.submit t('helpers.submit.update') %>
  </div>
  <%= link_to "戻る", users_path, class: "btn btn-secondary" %>
<% end %>
